# Public Supabase config (anon key + URL only — never the service-role key).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Base URL of the @fa/web Next.js app (used to call API routes for things mobile
# can't do directly, e.g. Plaid exchange, Stripe Checkout session creation).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
