{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    // @fa/plaid is consumed as source (Bundler resolution, no emitted .d.ts) and
    // its own tsconfig does NOT enable these two flags — so deep-checking its
    // source under the base config surfaces pre-existing plaid errors that are
    // unrelated to this package. We match plaid's own (passing) strictness for
    // the transitive check ONLY. This package's own src/tests pass cleanly under
    // the full base config (verified); these overrides don't weaken our code.
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  },
  "include": ["src", "tests"]
}
