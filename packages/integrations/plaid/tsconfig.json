{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "paths": {
      "@fa/db": ["../../db/src/index.ts"],
      "@fa/db/types": ["../../db/types/index.ts"],
      "@fa/claude": ["../claude/src/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
