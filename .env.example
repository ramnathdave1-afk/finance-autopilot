# Root .env.example — single source of truth for every env var the monorepo
# needs. Copy to .env (or .env.local for Next.js) and fill in.
#
# Naming:
#   NEXT_PUBLIC_*  — exposed to browser, safe to ship in client JS
#   EXPO_PUBLIC_*  — exposed to RN runtime, safe in mobile bundle
#   everything else — server-only, NEVER inline into client/mobile code
#
# Used-by column documents which package(s) read each var.

# --- Supabase ---------------------------------------------------------------
# used-by: @fa/db (service client), @fa/web (auth + RLS-respecting reads),
#          @fa/mobile (anon-key only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Mirror for Expo runtime (same values as NEXT_PUBLIC_*)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Database --------------------------------------------------------------
# used-by: scripts/setup.mjs (gates `pnpm --filter @fa/db migrate:apply`).
# Supabase Postgres connection string (Settings → Database → Connection string).
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Leave blank to skip migrations during `pnpm setup`.
DATABASE_URL=

# --- Plaid -----------------------------------------------------------------
# used-by: @fa/plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Webhook receiver URL (apps/web /api/plaid/webhook)
PLAID_WEBHOOK_URL=

# --- Anthropic (Claude) ----------------------------------------------------
# used-by: @fa/claude (categorization, agent reasoning, computer use fallback)
ANTHROPIC_API_KEY=

# --- Stripe ----------------------------------------------------------------
# used-by: @fa/stripe, apps/web /api/stripe/*
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Founder pricing — generate in Stripe dashboard, paste IDs here
STRIPE_PRICE_AUTOPILOT_MONTHLY=
STRIPE_PRICE_AUTOPILOT_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=
STRIPE_PRICE_FOUNDER_999_LIFETIME=
STRIPE_COUPON_FOUNDER_YEAR1_50PCT=

# --- Inngest ---------------------------------------------------------------
# used-by: @fa/inngest, apps/web /api/inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Browserbase / Stagehand ----------------------------------------------
# used-by: @fa/browserbase (subscription-killer agent)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Twilio (voice negotiation, Tier 2 — Phase 4) -------------------------
# used-by: @fa/twilio (when bill-negotiation ships)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# App endpoint Twilio fetches to voice the negotiation script. The agent appends
# the script as a query param. used-by: @fa/twilio placeCall, apps/web
# /api/voice/twiml. e.g. https://app.example.com/api/voice/twiml
TWILIO_VOICE_TWIML_URL=
# App endpoint Twilio POSTs call status callbacks to. used-by: @fa/twilio
# placeCall, apps/web /api/voice/status. e.g. https://app.example.com/api/voice/status
TWILIO_VOICE_STATUS_CALLBACK_URL=

# --- Push notifications ----------------------------------------------------
# used-by: @fa/inngest/notify (Expo Push primary, OneSignal fallback)
EXPO_ACCESS_TOKEN=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# --- TTS (voice memo briefing) --------------------------------------------
# used-by: @fa/inngest/voice (ElevenLabs primary, OpenAI TTS fallback)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
OPENAI_API_KEY=
OPENAI_TTS_VOICE=alloy

# --- Apps ------------------------------------------------------------------
# used-by: @fa/mobile (API base for fetches against @fa/web)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Observability ---------------------------------------------------------
# used-by: PostHog product analytics, Sentry error tracking
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
